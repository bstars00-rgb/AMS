# Trip.com Connect — the agent uses MANUAL login by default (you log in once in
# the opened browser, the session is saved to auth.json). Filling credentials
# here is optional and only used if you run auto-login.
TRIP_LOGIN_URL=https://connect.trip.com/login

# Optional auto-login (leave blank to log in manually — recommended & safer).
TRIP_EMAIL=
TRIP_PASSWORD=

# Confidence thresholds (same meaning as the AMS web app).
AUTO_THRESHOLD=90
REVIEW_THRESHOLD=65

# Scoring weights (relative). Includes Area + Smoke that Trip.com's screen shows.
W_NAME=25
W_BED=25
W_TYPE=15
W_GRADE=10
W_VIEW=10
W_AREA=10
W_SMOKE=5
